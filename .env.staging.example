# =============================================================================
# .env.staging — Environment config for the Hetzner staging deployment
#
# Copy to .env.staging and fill in your values:
#   cp .env.staging.example .env.staging
#
# Deploy to devbox with:
#   ./scripts/deploy-staging.sh --sync-env
#   ./scripts/deploy-staging.sh deploy          # also syncs env automatically
# =============================================================================

# ── LLM Configuration ───────────────────────────────────────────────────────
# Base URL and key used for extraction + query rewriting (and embeddings, unless overridden below)
OPENAI_API_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-...

# Models
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMS=1536
EXTRACTION_MODEL=gpt-4o-mini

# ── Embedding endpoint override ─────────────────────────────────────────────
# Use a different provider for embeddings (e.g., keep OpenAI for embeddings while
# using a HuggingFace/self-hosted endpoint for extraction). Falls back to OPENAI_API_URL/KEY.
# EMBEDDING_API_URL=https://api.openai.com/v1
# EMBEDDING_API_KEY=sk-...

# ── Authentication ──────────────────────────────────────────────────────────
# Bearer tokens for the MCP HTTP endpoint (comma-separated).
# Also used as admin credentials for the OAuth approval flow (X-Admin-Token header).
MCP_AUTH_TOKENS=

# OAuth 2.1: public base URL of this server. Enables OAuth discovery,
# dynamic client registration, and authorization code flow with PKCE.
# When set, MCP clients like Perplexity can connect via standard OAuth.
# MCP_OAUTH_ISSUER=https://mcp.example.com

# ── Security hardening ─────────────────────────────────────────────────────
# Token required for dynamic OAuth client registration. When set,
# POST /oauth/register must include "Authorization: Bearer <this-token>".
# IMPORTANT: Set this in production to prevent unauthorized client registration.
# MCP_OAUTH_REGISTRATION_TOKEN=

# Require auth tokens or OAuth when binding to non-loopback addresses (default: true).
# Set to false only if you have an external reverse-proxy handling auth.
MCP_REQUIRE_AUTH_FOR_WAN=true
