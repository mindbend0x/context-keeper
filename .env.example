# Every variable below also has a matching CLI flag on `context-keeper-mcp`
# and `context-keeper` (e.g. OPENAI_API_KEY ↔ --api-key,
# EMBEDDING_MODEL ↔ --embedding-model-name). Either form works; CLI flags
# override env vars when both are set. This means you can also configure the
# server inline via `npx context-keeper-mcp --api-url ... --api-key ...`.

# Optional: LLM-powered extraction (without these, mock extraction is used)
# OPENAI_API_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-...
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMS=1536
# EXTRACTION_MODEL=gpt-4o-mini

# Optional: separate endpoint for embeddings (falls back to OPENAI_API_URL/KEY)
# EMBEDDING_API_URL=https://api.openai.com/v1
# EMBEDDING_API_KEY=sk-...

# Storage: "memory" (default) or "rocksdb:./data"
# STORAGE_BACKEND=memory

# ── Authentication ──────────────────────────────────────────────────────
# Static bearer tokens (comma-separated). Required for HTTP transport unless
# MCP_OAUTH_ISSUER is set or MCP_ALLOW_INSECURE_HTTP=1.
# Also used as admin credentials for the OAuth approval flow (X-Admin-Token header).
# MCP_AUTH_TOKENS=token1,token2

# OAuth 2.1: public base URL of this server. Enables OAuth discovery,
# dynamic client registration, and authorization code flow with PKCE.
# MCP_OAUTH_ISSUER=https://mcp.example.com

# ── Security hardening ─────────────────────────────────────────────────
# Token required for dynamic OAuth client registration. When set,
# POST /oauth/register must include "Authorization: Bearer <this-token>".
# Leave unset for open registration (backward compatible).
# MCP_OAUTH_REGISTRATION_TOKEN=

# Require auth tokens or OAuth when binding to non-loopback addresses (default: true).
# Set to false only if you have an external reverse-proxy handling auth.
# MCP_REQUIRE_AUTH_FOR_WAN=true

# ── Telemetry (opt-in, anonymous) ──────────────────────────────────────
# Context Keeper does not ship a default OTLP endpoint. On first CLI run
# you will be prompted to opt in; consent is stored in
# ~/.context-keeper/config.toml with a random install_id. When enabled,
# events (cli.install, cli.invoke, cli.error) are exported to whatever
# OTLP receiver you point at below.
#
# Hard kill switch — overrides stored consent for this process. Set to 1
# in CI, containers, or any environment where telemetry must not emit.
# CK_TELEMETRY_DISABLE=1
#
# Standard OpenTelemetry environment variables (honoured by
# opentelemetry-otlp). Point these at your own receiver — e.g.
# otel-desktop-viewer, an OpenTelemetry Collector, Honeycomb, etc.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_EXPORTER_OTLP_HEADERS=api-key=...,x-tenant=...
# OTEL_EXPORTER_OTLP_PROTOCOL=grpc
# OTEL_SERVICE_NAME=context-keeper-cli
