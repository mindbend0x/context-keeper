# Optional: LLM-powered extraction (without these, mock extraction is used)
# OPENAI_API_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-...
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMS=1536
# EXTRACTION_MODEL=gpt-4o-mini

# Optional: separate endpoint for embeddings (falls back to OPENAI_API_URL/KEY)
# EMBEDDING_API_URL=https://api.openai.com/v1
# EMBEDDING_API_KEY=sk-...

# Storage: "memory" (default) or "rocksdb:./data"
# STORAGE_BACKEND=memory

# ── Authentication ──────────────────────────────────────────────────────
# Static bearer tokens (comma-separated). Required for HTTP transport unless
# MCP_OAUTH_ISSUER is set or MCP_ALLOW_INSECURE_HTTP=1.
# MCP_AUTH_TOKENS=token1,token2

# OAuth 2.1: public base URL of this server. Enables OAuth discovery,
# dynamic client registration, and authorization code flow with PKCE.
# MCP_OAUTH_ISSUER=https://mcp.example.com
